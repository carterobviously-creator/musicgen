=========================================\n * \n * Arcade-safe Neural Music Generator\n * \n * \"Real\" small NN-ish model: 7 -> 8 -> 7\n * \n * Uses 1D arrays ONLY (no number[][], no softmax/exp)\n * \n * ==========================================\n */\n/**\n * Scratch buffers (re-used)\n */\ncontroller.B.onEvent(ControllerButtonEvent.Pressed, function () {\n    generateAndPlay(24)\n})\n// --------- Controls ----------\ncontroller.A.onEvent(ControllerButtonEvent.Pressed, function () {\n    initNet()\n    train(300)\n    game.splash(\"Trained!\", \"Press B to play\")\n})\n// Play generated melody\nfunction generateAndPlay (steps: number) {\n    if (!(trained)) {\n        game.splash(\"Train first\", \"Press A\")\n        return\n"]]},{"start1":716,"length1":0,"diffs":[[1,"    // 【1-4575e8】\n    current = randint(0, N - 1)\n    // higher = more random\n    chaos = 35\n    for (let index = 0; index < steps; index++) {\n        current = nextNote(current, chaos)\n        // 【2-e2258f】\n        music.playTone(NOTES[current], NOTE_MS)\n        // 【3-a440d2】\n        pause(NOTE_MS)\n    }\n"]]},{"start1":1025,"length1":609,"diffs":[[1,"// --------- helpers ----------\n// randint(min,max) 【1-4575e8】\nfunction rw () {\n    // random weight in [-0.7, 0.7]\n    return randint(-70, 70) / 100\n"]]},{"start1":1177,"length1":1344,"diffs":[[1,"// Argmax of out[]\nfunction argmaxOut () {\n    bestV = out[0]\n    for (let m = 1; m < N; m++) {\n        if (out[m] > bestV) {\n            bestV = out[m]\n            bestI = m\n        }\n"]]},{"start1":1368,"length1":127,"diffs":[[1,"return bestI\n"]]},{"start1":1383,"length1":256,"diffs":[[1,"// Generate next note using \"argmax + noise\"\n// add small random noise to each score so it varies\nfunction nextNote (current: number, chaos: number) {\n    forward(current)\n    bestV2 = out[0] + randint(0 - chaos, chaos) / 100\n    for (let v = 1; v < N; v++) {\n        let w = out[v] + (randint(-chaos, chaos) / 100)\n        if (w > bestV2) {\n            bestV2 = w\n            bestI2 = v\n        }\n"]]},{"start1":1787,"length1":176,"diffs":[[1,"return bestI2\n"]]},{"start1":1803,"length1":963,"diffs":[[1,"// Train using a multiclass perceptron-style update\nfunction train (epochs: number) {\n    for (let index = 0; index < epochs; index++) {\n        for (let N = 0; N <= TRAIN.length - 1; N++) {\n            melody = TRAIN[N]\n            for (let u = 0; u <= melody.length - 1 - 1; u++) {\n                inp = melody[u]\n                target = melody[u + 1]\n                forward(inp)\n                pred = argmaxOut()\n"]]},{"start1":2298,"length1":200,"diffs":[[1,"B2[pred] -= LR2\nfor (let q = 0; q <= H - 1; q++) {\n                        W2[target * H + q] += LR2 * a1[q]\nW2[pred * H + q] -= LR2 * a1[q]\n"]]},{"start1":2461,"length1":351,"diffs":[[1,"                    // Back-ish update to hidden weights for this input note\n                    // deltaH ~ (W2[target,h] - W2[pred,h]) * relu'(z1)\n                    for (let r = 0; r <= H - 1; r++) {\n                        if (z1[r] > 0) {\n                            dh = W2[target * H + r] - W2[pred * H + r]\n                            B1[r] += LR1 * dh\nW1[r * N + inp] += LR1 * dh\n"]]},{"start1":2947,"length1":0,"diffs":[[1,"    trained = true\n"]]},{"start1":2968,"length1":544,"diffs":[[1,"function initNet () {\n    W1 = []\n    B1 = []\n    W2 = []\n    B2 = []\n    z1 = []\n    a1 = []\n    out = []\n    for (let index = 0; index < H; index++) {\n        B1.push(rw())\n        z1.push(0)\n        a1.push(0)\n        for (let index = 0; index < N; index++) {\n            W1.push(rw())\n        }\n    }\n    for (let index = 0; index < N; index++) {\n        B2.push(rw())\n        out.push(0)\n        for (let index = 0; index < H; index++) {\n            W2.push(rw())\n        }\n    }\n"]]},{"start1":3455,"length1":363,"diffs":[[1,"// Forward pass for a ONE-HOT input note index \"inp\"\nfunction forward (inp: number) {\n    // Hidden layer: z1[h] = B1[h] + W1[h,inp]\n    for (let k = 0; k <= H - 1; k++) {\n        s = B1[k] + W1[k * N + inp]\n        z1[k] = s\n        a1[k] = relu(s)\n"]]},{"start1":3711,"length1":28,"diffs":[[1,"    // Output layer: out[o] = B2[o] + sum_h W2[o,h]*a1[h]\n    for (let p = 0; p <= N - 1; p++) {\n        t = B2[p]\n        base = p * H\n        for (let l = 0; l <= H - 1; l++) {\n            t += W2[base + l] * a1[l]\n        }\n        out[p] = t\n    }\n"]]},{"start1":3965,"length1":309,"diffs":[[1,"function relu (x: number) {\n    return x > 0 ? x : 0\n}\nlet base = 0\nlet t = 0\nlet s = 0\nlet dh = 0\nlet z1: number[] = []\nlet pred = 0\nlet target = 0\nlet inp = 0\nlet melody: number[] = []\nlet bestV2 = 0\nlet bestV = 0\nlet chaos = 0\nlet current = 0\nlet trained = false\nlet TRAIN: number[][] = []\nlet NOTE_MS = 0\nlet H = 0\nlet N = 0\nlet NOTES: number[] = []\nlet out: number[] = []\nlet a1: number[] = []\n// size N\nlet B2: number[] = []\n// size N*H, index = o*H + h\nlet W2: number[] = []\n// size H\nlet B1: number[] = []\n// Weights as FLAT arrays (1D)\n// size H*N, index = h*N + i\nlet W1: number[] = []\nlet bestI2 = 0\nlet bestI = 0\n// Notes (C D E F G A B)\nNOTES = [\n262,\n294,\n330,\n349,\n392,\n440,\n494\n]\nN = NOTES.length\n// Network sizes\nH = 8\n// Learning rates\n// output layer\nlet LR2 = 0.08\n// hidden layer\nlet LR1 = 0.02\n// Sound timing\nNOTE_MS = 180\n// --------- Training data (note indices) ----------\nTRAIN = [\n[\n0,\n2,\n4,\n5,\n4,\n2,\n0\n],\n[\n0,\n3,\n5,\n6,\n5,\n3,\n0\n],\n[\n4,\n2,\n0,\n2,\n4,\n5,\n4\n],\n[\n5,\n4,\n2,\n0,\n2,\n4,\n5\n],\n[\n0,\n1,\n2,\n3,\n4,\n3,\n2,\n1\n]\n]\n"]]}]},{"type":"edited","filename":"pxt.json","patch":[{"start1":207,"length1":31,"diffs":[[1,"    \"preferredEditor\": \"blocksprj\"\n"]]}]}]},{"timestamp":1777425106359,"editorVersion":"4.0.14","changes":[{"type":"edited","filename":"main.blocks","patch":[{"start1":0,"length1":2348,"diffs":[[1,"<xml xmlns=\"https://developers.google.com/
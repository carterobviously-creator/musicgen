hen mostly chorus/verse alternation\n"]]},{"start1":9352,"length1":96,"diffs":[[1,"function nameOfSec(s: number): string {\n    if (s == 0) return \"INTRO\"\n    if (s == 1) return \"VERSE\"\n    if (s == 2) return \"CHORUS\"\n    return \"BRIDGE\"\n}\n\n// temperature per section\nfunction tempForSec(s: number): number {\n    if (s == 0) return 0.20\n    if (s == 1) return 0.35\n"]]},{"start1":9661,"length1":16,"diffs":[[1,"    return 0.45\n"]]},{"start1":9679,"length1":183,"diffs":[[1,"\n// lead density per section\nfunction leadEverySteps(s: number): number {\n    if (s == 0) return 4   // sparse\n    if (s == 1) return 2   // medium\n    if (s == 2) return 1   // busy\n    return 2\n"]]},{"start1":9878,"length1":108,"diffs":[[1,"// ---------- HOOK MOTIF ----------\nlet motif: number[] = [0, 2, 4, 2, 5, 4, 2, 0] // 8 steps\nfunction motifNote(step8: number, chordRoot: number): number {\n    // shift motif to chord root\n    let n = motif[step8 & 7] + chordRoot\n    while (n > 7) n -= 7\n    if (n < 0) n = 0\n    return n & 7\n}\n"]]},{"start1":10175,"length1":81,"diffs":[[1,"// ---------- MAIN GENERATION ----------\nlet curNote = randint(0, 7)\nlet lastNote = curNote\n"]]},{"start1":10268,"length1":175,"diffs":[[1,"function tick() {\n    if (!running) return\n"]]},{"start1":10312,"length1":302,"diffs":[[1,"    if (barIndex >= bars) {\n        running = false\n        music.stopAllSounds()\n        game.splash(\"Done\", \"Press A for new\")\n        return\n"]]},{"start1":10463,"length1":91,"diffs":[[1,"    let sec = sectionOfBar(barIndex)\n    sectionName = nameOfSec(sec)\n"]]},{"start1":10534,"length1":141,"diffs":[[1,"    let chordRoot = prog[barIndex & 3] & 7\n    let beatGroup = (step16 >> 2) & 3 // 0..3 per bar\n"]]},{"start1":10632,"length1":83,"diffs":[[1,"    // drums\n    if (kick[step16]) { playKick(); flash = 2; eq[step16] = 90 }\n    if (snare[step16]) { playSnare(); eq[(step16 + 4) & 15] = 70 }\n    if (hat[step16]) { playHat(); eq[(step16 + 8) & 15]